# ─── Database (Supabase) ──────────────────────────────────────────────────────
# Gunakan Transaction Pooler (port 6543) untuk runtime
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Gunakan Direct Connection (port 5432) untuk prisma migrate / db push
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# ─── Redis (Upstash) ──────────────────────────────────────────────────────────
REDIS_URL="rediss://:[PASSWORD]@[HOST].upstash.io:6379"

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET="your-super-secret-jwt-key-minimum-32-characters-long"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="30d"

# ─── Cookie ───────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
COOKIE_SECRET="your-cookie-secret-minimum-32-characters-long"

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3001/auth/google/callback"

# ─── App ─────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV="development"
FRONTEND_URL="http://localhost:3000"

# ─── Sentry (opsional di dev) ─────────────────────────────────────────────────
SENTRY_DSN=""

# ─── AI Services ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-your-key"
OPENAI_API_KEY="sk-your-openai-key-for-whisper"

# ─── Storage (Cloudflare R2) ──────────────────────────────────────────────────
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="nihongo-assets"
R2_PUBLIC_URL="https://assets.nihongo.id"

# ─── Payment (Midtrans) ───────────────────────────────────────────────────────
MIDTRANS_SERVER_KEY=""
MIDTRANS_CLIENT_KEY=""
MIDTRANS_IS_PRODUCTION=false
